{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Linux Install Simulator",
  "version": "0.1.0",
  "identifier": "com.sarah.linux-linst-app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Linuxインストールシミュレーター",
        "width": 900,
        "height": 950,
	"center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/badge-32.png",
      "icons/badge-64.png",
      "icons/badge-128.png",
      "icons/badge-256.png",
      "icons/badge-512.png",
      "icons/badge.ico"
    ]
  }
}
